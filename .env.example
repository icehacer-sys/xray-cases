# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# --- Secrets ---
ANTHROPIC_API_KEY=
# Long-lived Threads token for @mdnoteslab (reuse the one from the threads bot).
THREADS_ACCESS_TOKEN=
# Long-lived Instagram token for @mdnoteslab (reuse the one from the ig bot).
IG_ACCESS_TOKEN=
# Facebook Page ("Weird X-Ray Case Files") id + a long-lived Page access token.
# Get both from the Graph API Explorer / a System User token (see FACEBOOK_SETUP.md).
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# --- Image hosting (GitHub raw URLs) ---
# Base raw URL for THIS repo, used to turn a case's image filenames into public URLs
# the Threads/Instagram publish APIs can fetch. Form:
#   https://raw.githubusercontent.com/<user>/<repo>/<branch>
# A case image then resolves to:  <GITHUB_RAW_BASE>/cases/<caseFolder>/<filename>
GITHUB_RAW_BASE=https://raw.githubusercontent.com/icehacer-sys/xray-cases/main

# --- Tuning (safe defaults) ---
# BOT_MODEL=claude-sonnet-4-6
# Minutes after the challenge post to publish the pinned Answer reply.
# BOT_ANSWER_DELAY_MIN=60
# Minutes after the challenge post to publish the CTA sub-reply (under the Answer).
# BOT_CTA_DELAY_MIN=90
# Timezone for any human-readable scheduling logs.
# BOT_ACTIVE_TZ=Africa/Cairo
# Also cross-post the carousel to Instagram (publishing to your own account may work
# in dev mode; if Instagram rejects it the case still posts to Threads).
# BOT_INSTAGRAM=on
# Cross-post the daily challenge photo to the Facebook Page (needs FB_PAGE_ID + FB_PAGE_ACCESS_TOKEN).
# BOT_FACEBOOK=on
# Post the challenge to Facebook this many minutes BEFORE Threads (early access for FB followers).
# BOT_FB_LEAD_MIN=10
# Required to actually post in live mode. Must equal "yes".
# BOT_CONFIRM_LIVE=
